<!DOCTYPE html>

<html dir="rtl" lang="ar"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-error": "#ffffff",
                        "secondary-fixed-dim": "#71dba6",
                        "primary-fixed": "#dae2ff",
                        "secondary-container": "#8af5be",
                        "tertiary": "#940010",
                        "on-background": "#191c1d",
                        "on-secondary-fixed": "#002113",
                        "on-tertiary-fixed": "#410003",
                        "surface-dim": "#d9dadb",
                        "on-surface": "#191c1d",
                        "on-primary": "#ffffff",
                        "outline": "#737785",
                        "inverse-primary": "#b2c5ff",
                        "surface-container-highest": "#e1e3e4",
                        "error": "#ba1a1a",
                        "on-primary-fixed-variant": "#0040a1",
                        "on-primary-fixed": "#001847",
                        "surface-container": "#edeeef",
                        "on-error-container": "#93000a",
                        "inverse-on-surface": "#f0f1f2",
                        "tertiary-container": "#ba1b20",
                        "tertiary-fixed": "#ffdad6",
                        "primary": "#0040a1",
                        "surface-tint": "#0056d2",
                        "outline-variant": "#c3c6d6",
                        "on-secondary-fixed-variant": "#005235",
                        "background": "#f8f9fa",
                        "on-tertiary-container": "#ffcdc8",
                        "secondary": "#006c47",
                        "on-secondary-container": "#00714b",
                        "surface-container-low": "#f3f4f5",
                        "primary-container": "#0056d2",
                        "on-tertiary": "#ffffff",
                        "error-container": "#ffdad6",
                        "tertiary-fixed-dim": "#ffb3ac",
                        "secondary-fixed": "#8df7c1",
                        "surface-bright": "#f8f9fa",
                        "on-primary-container": "#ccd8ff",
                        "on-secondary": "#ffffff",
                        "on-surface-variant": "#424654",
                        "surface": "#f8f9fa",
                        "inverse-surface": "#2e3132",
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed-dim": "#b2c5ff",
                        "on-tertiary-fixed-variant": "#930010",
                        "surface-variant": "#e1e3e4",
                        "surface-container-high": "#e7e8e9"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
<style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }
        h1, h2, h3 {
            font-family: 'Manrope', sans-serif;
        }
        .primary-gradient {
            background: linear-gradient(135deg, #0040a1 0%, #0056d2 100%);
        }
        .ghost-border {
            outline: 1px solid rgba(195, 198, 214, 0.15);
        }
        input:focus, select:focus {
            outline: 1px solid #0040a1 !important;
            border-color: transparent !important;
            box-shadow: none !important;
        }
    </style>
</head>
<body class="bg-surface text-on-surface flex flex-col min-h-screen items-center justify-center p-6">
<div class="w-full max-w-md flex flex-col items-center">
<!-- Brand Header -->
<header class="text-center mb-12">
<h1 class="text-2xl font-extrabold text-primary mb-2 tracking-tight">
                تسجيل الحضور للطلبة
            </h1>
<p class="text-on-surface-variant text-lg">
                مرحبًا بك
            </p>
</header>
<!-- Login Container -->
<main class="w-full bg-surface-container-lowest p-8 rounded-xl ghost-border">
<div class="mb-8">
<h2 class="text-xl font-bold text-on-surface">
                    تسجيل الدخول
                </h2>
</div>
<form class="space-y-6">
<!-- User Type Selection -->
<div class="space-y-2">
<label class="block text-sm font-medium text-on-surface-variant px-1">نوع المستخدم</label>
<select class="w-full bg-surface-variant border-none rounded-lg py-3 px-4 text-on-surface appearance-none cursor-pointer">
<option value="student">طالب</option>
<option value="teacher">أستاذ</option>
<option value="admin">إداري</option>
</select>
</div>
<!-- Email Input -->
<div class="space-y-2">
<label class="block text-sm font-medium text-on-surface-variant px-1">البريد الإلكتروني</label>
<input class="w-full bg-surface-variant border-none rounded-lg py-3 px-4 text-on-surface placeholder:text-outline/50" placeholder="example@domain.com" type="email"/>
</div>
<!-- Password Input -->
<div class="space-y-2">
<label class="block text-sm font-medium text-on-surface-variant px-1">كلمة المرور</label>
<input class="w-full bg-surface-variant border-none rounded-lg py-3 px-4 text-on-surface placeholder:text-outline/50" placeholder="••••••••" type="password"/>
</div>
<!-- Login Button -->
<button class="w-full primary-gradient text-on-primary font-bold py-4 rounded-xl shadow-lg hover:opacity-90 transition-opacity mt-4" type="submit">
                    تسجيل الدخول
                </button>
</form>
</main>
</div>
</body></html>
